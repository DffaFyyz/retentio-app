generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserStatus {
   ACTIVE
   INACTIVE
   SUSPENDED
}

enum UserRole {
   CS_AGENT
   MANAGER
}

enum RiskLevel {
   LOW
   HIGH
}

enum PredictionStatus {
   PENDING
   SUCCESS
   FAILED
}

enum CaseStatus {
   OPEN
   IN_PROGRESS
   RESOLVED
   CLOSED
}

enum CasePriority {
   LOW
   MEDIUM
   HIGH
}

enum OutreachChannel {
   PHONE
   EMAIL
   WHATSAPP
   SMS
   IN_APP
   OTHER
}

enum OutreachOutcome {
   CONTACTED
   NO_RESPONSE
   INTERESTED
   NOT_INTERESTED
   COMPLAINED
   ESCALATED
   FOLLOW_UP_NEEDED
}

enum OfferType {
   DISCOUNT
   CONTRACT_UPGRADE
   FREE_SUPPORT
   SERVICE_BUNDLE
   DEVICE_PROTECTION
   CUSTOM
}

enum OfferStatus {
   OFFERED
   ACCEPTED
   REJECTED
   EXPIRED
   CANCELLED
}

enum CaseResolutionOutcome {
   RETAINED
   OFFER_ACCEPTED
   OFFER_REJECTED
   CUSTOMER_UNREACHABLE
   CHURN_CONFIRMED
   OTHER
}

// ==========================================
// USER & AUTH
// ==========================================

model User {
   id            String     @id @default(cuid())
   name          String
   email         String     @unique
   emailVerified Boolean    @default(false)
   image         String?
   status        UserStatus @default(ACTIVE)
   role          UserRole   @default(CS_AGENT)
   createdAt     DateTime   @default(now()) @db.Timestamp(0)
   updatedAt     DateTime   @updatedAt

   sessions Session[]
   accounts Account[]
   assignedInterventionCases InterventionCase[] @relation("InterventionCaseAssignedTo")
   createdInterventionCases  InterventionCase[] @relation("InterventionCaseCreatedBy")
   outreachLogs              OutreachLog[]      @relation("OutreachLogAgent")
   retentionOffers           RetentionOffer[]   @relation("RetentionOfferOfferedBy")

   @@map("users")
}

model Session {
   id        String   @id @default(cuid())
   token     String   @unique
   expiresAt DateTime
   ipAddress String?
   userAgent String?
   userId    String
   createdAt DateTime @default(now()) @db.Timestamp(0)
   updatedAt DateTime @updatedAt

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@map("sessions")
}

model Account {
   id                    String    @id @default(cuid())
   accountId             String
   providerId            String
   userId                String
   accessToken           String?   @db.Text
   refreshToken          String?   @db.Text
   idToken               String?   @db.Text
   accessTokenExpiresAt  DateTime?
   refreshTokenExpiresAt DateTime?
   scope                 String?   @db.Text
   password              String?   @db.Text
   createdAt             DateTime  @default(now()) @db.Timestamp(0)
   updatedAt             DateTime  @updatedAt

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@map("accounts")
}

model Verification {
   id         String    @id @default(cuid())
   identifier String
   value      String
   expiresAt  DateTime
   createdAt  DateTime? @default(now()) @db.Timestamp(0)
   updatedAt  DateTime? @updatedAt

   @@map("verifications")
}

// ==========================================
// CUSTOMERS
// ==========================================

model Customer {
   customerID       String     @id @db.VarChar(100)
   fullName         String?    @db.VarChar(150)
   gender           String     @db.VarChar(20)
   SeniorCitizen    Int
   Partner          String     @db.VarChar(10)
   Dependents       String     @db.VarChar(10)
   tenure           Int
   Contract         String     @db.VarChar(50)
   PaperlessBilling String     @db.VarChar(10)
   PaymentMethod    String     @db.VarChar(100)
   MonthlyCharges   Float
   TotalCharges     Float
   PhoneService     String     @db.VarChar(10)
   MultipleLines    String     @db.VarChar(30)
   InternetService  String     @db.VarChar(50)
   OnlineSecurity   String     @db.VarChar(30)
   OnlineBackup     String     @db.VarChar(30)
   DeviceProtection String     @db.VarChar(30)
   TechSupport      String     @db.VarChar(30)
   StreamingTV      String     @db.VarChar(30)
   StreamingMovies  String     @db.VarChar(30)
   Churn            String     @db.VarChar(10)
   churnProbability Float      @default(0)
   riskLevel        RiskLevel?
   riskFactors      Json?
   lastPredictedAt  DateTime?
   predictionStatus PredictionStatus @default(PENDING)
   predictionError  String?
   createdAt        DateTime   @default(now()) @db.Timestamp(0)
   updatedAt        DateTime   @updatedAt

   predictionLogs PredictionLog[]
   interventionCases InterventionCase[]
   outreachLogs      OutreachLog[]
   retentionOffers   RetentionOffer[]

   @@map("customers")
}

model PredictionLog {
   id               String    @id @default(cuid())
   customerID       String    @db.VarChar(100)
   churnProbability Float
   riskLevel        RiskLevel
   topFactors       Json?
   modelVersion     String?   @db.VarChar(100)
   threshold        Float?
   createdAt        DateTime  @default(now()) @db.Timestamp(0)

   customer Customer @relation(fields: [customerID], references: [customerID], onDelete: Cascade)

   @@index([customerID])
   @@index([createdAt])
   @@map("prediction_logs")
}

model InterventionCase {
   id                       String       @id @default(cuid())
   customerID               String       @db.VarChar(100)
   assignedToId             String?
   createdById              String?
   status                   CaseStatus   @default(OPEN)
   priority                 CasePriority @default(MEDIUM)
   title                    String?      @db.VarChar(200)
   reason                   String?      @db.Text
   churnProbabilitySnapshot Float
   riskLevelSnapshot        RiskLevel?
   riskFactorsSnapshot      Json?
   recommendedActions       Json?
   resolutionOutcome        CaseResolutionOutcome?
   resolutionNote           String?      @db.Text
   finalOutreachLogId       String?
   finalOfferId             String?
   resolvedAt               DateTime?
   closedAt                 DateTime?
   createdAt                DateTime     @default(now()) @db.Timestamp(0)
   updatedAt                DateTime     @updatedAt

   customer        Customer         @relation(fields: [customerID], references: [customerID], onDelete: Cascade)
   assignedTo      User?            @relation("InterventionCaseAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
   createdBy       User?            @relation("InterventionCaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
   outreachLogs    OutreachLog[]
   retentionOffers RetentionOffer[]

   @@index([customerID])
   @@index([assignedToId])
   @@index([createdById])
   @@index([status])
   @@index([priority])
   @@map("intervention_cases")
}

model OutreachLog {
   id             String           @id @default(cuid())
   caseId         String
   customerID     String           @db.VarChar(100)
   agentId        String?
   channel        OutreachChannel
   outcome        OutreachOutcome
   notes          String?          @db.Text
   nextFollowUpAt DateTime?
   createdAt      DateTime         @default(now()) @db.Timestamp(0)
   updatedAt      DateTime         @updatedAt

   case     InterventionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
   customer Customer         @relation(fields: [customerID], references: [customerID], onDelete: Cascade)
   agent    User?            @relation("OutreachLogAgent", fields: [agentId], references: [id], onDelete: SetNull)

   @@index([caseId])
   @@index([customerID])
   @@index([agentId])
   @@map("outreach_logs")
}

model RetentionOffer {
   id              String      @id @default(cuid())
   caseId          String
   customerID      String      @db.VarChar(100)
   offeredById     String?
   offerType       OfferType
   title           String      @db.VarChar(200)
   description     String?     @db.Text
   discountPercent Float?
   discountAmount  Float?
   durationMonths  Int?
   status          OfferStatus @default(OFFERED)
   offeredAt       DateTime    @default(now()) @db.Timestamp(0)
   respondedAt     DateTime?
   createdAt       DateTime    @default(now()) @db.Timestamp(0)
   updatedAt       DateTime    @updatedAt

   case      InterventionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
   customer  Customer         @relation(fields: [customerID], references: [customerID], onDelete: Cascade)
   offeredBy User?            @relation("RetentionOfferOfferedBy", fields: [offeredById], references: [id], onDelete: SetNull)

   @@index([caseId])
   @@index([customerID])
   @@index([offeredById])
   @@map("retention_offers")
}
