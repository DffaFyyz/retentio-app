NODE_ENV=production

POSTGRES_USER=retentio
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=retentio
# Used only when running backend/Prisma outside Docker. Docker Compose builds the
# container DATABASE_URL from the Postgres variables above.
DATABASE_URL=postgresql://retentio:change-this-password@postgres:5432/retentio?schema=public
RUN_DATABASE_SEED=false
SEED_CS_AGENT_NAME=Retentio CS Agent
SEED_CS_AGENT_EMAIL=agent@retentio.local
SEED_CS_AGENT_PASSWORD=change-this-agent-password
SEED_MANAGER_NAME=Retentio Manager
SEED_MANAGER_EMAIL=manager@retentio.local
SEED_MANAGER_PASSWORD=change-this-manager-password

BETTER_AUTH_SECRET=change-this-to-a-long-random-secret
BETTER_AUTH_URL=http://103.152.242.177
FRONTEND_URL=http://103.152.242.177

ML_SERVICE_URL=http://ml-service:5000
ML_MODEL_VERSION=xgboost_churn_model
ML_RISK_THRESHOLD=0.59

VITE_API_URL=/api
